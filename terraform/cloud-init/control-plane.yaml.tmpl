#cloud-config
package_update: true
package_upgrade: false
runcmd:
  - swapoff -a
  - sed -ri '/\sswap\s/s/^#?/#/' /etc/fstab
  - modprobe overlay
  - modprobe br_netfilter
  - sh -c 'printf "overlay\nbr_netfilter\n" > /etc/modules-load.d/k8s.conf'
  - sh -c 'printf "net.bridge.bridge-nf-call-iptables = 1\nnet.bridge.bridge-nf-call-ip6tables = 1\nnet.ipv4.ip_forward = 1\n" > /etc/sysctl.d/99-kubernetes-cri.conf'
  - sysctl --system
  - apt-get update
  - apt-get install -y ca-certificates curl gnupg lsb-release apt-transport-https
  - mkdir -p /etc/apt/keyrings
  - sh -c 'curl -fsSL https://pkgs.k8s.io/core:/stable:/${k8s_repo_channel}/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg'
  - sh -c 'echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/${k8s_repo_channel}/deb/ /" > /etc/apt/sources.list.d/kubernetes.list'
  - apt-get update
  - apt-get install -y containerd kubelet kubeadm kubectl
  - apt-mark hold kubelet kubeadm kubectl
  - mkdir -p /etc/containerd
  - sh -c 'containerd config default > /etc/containerd/config.toml'
  - sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml
  - systemctl restart containerd
  - systemctl enable containerd
  - kubeadm init --token ${k8s_join_token} --token-ttl 0 --apiserver-advertise-address ${control_plane_private_ip} --apiserver-cert-extra-sans ${control_plane_public_ip} --pod-network-cidr ${k8s_pod_cidr}
  - mkdir -p /root/.kube
  - cp /etc/kubernetes/admin.conf /root/.kube/config
  - |
    echo "BEGIN K8S_ADMIN_KUBECONFIG_B64"
    base64 -w0 /etc/kubernetes/admin.conf
    echo
    echo "END K8S_ADMIN_KUBECONFIG_B64"
  - sh -c 'kubectl --kubeconfig=/etc/kubernetes/admin.conf apply -f https://github.com/flannel-io/flannel/releases/latest/download/kube-flannel.yml'
