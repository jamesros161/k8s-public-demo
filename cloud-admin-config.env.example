# Copy this file, fill values, then encode:
#   base64 -w0 cloud-admin-config.env > cloud-admin-config.b64
# Store the output in GitHub Secret: CLOUD_ADMIN_CONFIG_B64

# OpenStack auth (used by provision/destroy workflows)
OS_AUTH_URL=https://your-keystone.example/v3
OS_REGION_NAME=RegionOne
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3
OS_AUTH_TYPE=v3applicationcredential
OS_APPLICATION_CREDENTIAL_ID=<app-cred-id>
OS_APPLICATION_CREDENTIAL_SECRET=<app-cred-secret>

# Node image / access for Terraform + cloud-init kubeadm cluster provisioning
K8S_IMAGE_NAME=
K8S_FLAVOR_NAME=
KUBECONFIG_ARTIFACT_PASSPHRASE=
TF_VAR_cluster_name=vpc-demo-cluster
TF_VAR_k8s_enabled=true
TF_VAR_k8s_worker_count=2
TF_VAR_k8s_worker_max_count=10
TF_VAR_k8s_repo_channel=v1.29
TF_VAR_k8s_join_token=abcdef.0123456789abcdef
TF_VAR_k8s_pod_cidr=10.244.0.0/16
# Single CIDR or comma-separated CIDRs are supported.
TF_VAR_k8s_ssh_allowed_cidr=0.0.0.0/0
TF_VAR_k8s_api_allowed_cidr=0.0.0.0/0

# Terraform networking overrides
TF_VAR_attach_to_existing_router_id=
TF_VAR_existing_network_id=
TF_VAR_network_name_suffix=

# Terraform remote state (S3-compatible)
TF_STATE_S3_BUCKET=
TF_STATE_S3_KEY=k8s-demo/terraform.tfstate
TF_STATE_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App + DNS + ACME
LETSENCRYPT_EMAIL=
LETSENCRYPT_USE_STAGING=false
TRAEFIK_SERVICE_TYPE=LoadBalancer
DEMO_DOMAIN_BASE=
DEMO_DB_PASSWORD=
DEMO_DB_ROOT_PASSWORD=

# Autoscaling stack values (required for provisioning)
# Defaults are derived automatically from Terraform values:
# - AS_CLUSTER_NAME defaults to TF_VAR_cluster_name
# - AS_GROUP_NAME defaults to "${AS_CLUSTER_NAME}-worker"
# - AS_NODES_MIN_SIZE defaults to TF_VAR_k8s_worker_count
# - AS_NODES_MAX_SIZE defaults to TF_VAR_k8s_worker_max_count
# Optional overrides:
# AS_CLUSTER_NAME=
# AS_GROUP_NAME=
# AS_NODES_MIN_SIZE=
# AS_NODES_MAX_SIZE=
# Optional chart version pins
METRICS_SERVER_CHART_VERSION=
CLUSTER_AUTOSCALER_CHART_VERSION=
CINDER_CSI_CHART_VERSION=
CINDER_CSI_STORAGECLASS_NAME=cinder-csi
CINDER_CSI_SET_DEFAULT_SC=true
OPENSTACK_CCM_CHART_VERSION=
OPENSTACK_CCM_USE_OCTAVIA=true
# Optional autoscaler image override. Defaults to registry.k8s.io/autoscaling/cluster-autoscaler:v<k8s minor>.0
# CLUSTER_AUTOSCALER_IMAGE_REPOSITORY=registry.k8s.io/autoscaling/cluster-autoscaler
# CLUSTER_AUTOSCALER_IMAGE_TAG=v1.29.0
